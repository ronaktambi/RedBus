    #head{
    width: 80%;
    margin: auto;
    position: relative ;
    top: 150px;
}

.bg h1{
    width: 35%;
    color: white;
    font-size: 45px;
}
#from{
    background-color: white;
    border-radius: 50px;
    display: flex;
    padding: 30px;
}
#from div{
    width: 33%;
    align-items: center;
}
#first{
    display: flex !important;
    border: 1px solid black;
    border-radius: 25px ;
}
#first div{
    align-content: center;
    display: flex;
    width: 50%;
}
#first div input{
    border: none;
    outline: none;
}
#second{
    display: flex;
    border: 1px solid black;
    border-radius: 25px ;
}
#second button{
    padding: 5px;
    border-radius: 20px;
    border: none;
    cursor: pointer;
}
#third{
    border: 1px solid black;
    border-radius: 25px;
    display: flex;
}
#third div{
    display: flex;
    justify-content: space-evenly;
   margin: auto;
}
#third button{
    padding: 15px 80px 12px 15px ;
    border-radius: 10px;
    /* border: none; */
    cursor: pointer;
}
#second i{
    padding-left: 80px;
}
#date p{
    padding-right: 10px;
}
#date p sub{
    color: red;
}




