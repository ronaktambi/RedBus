  <div class="bg">
        <div id="head">
            <h1>India's No. 1 online bus ticket booking site</h1>

            <div id="from">

                <div id="first">
                    <div>
                        <i class="bi bi-building-up"></i>
                        <input type="text" placeholder="FROM">
                    </div>
                    <div><i class="bi bi-building-down"></i>
                        <input type="text" placeholder="TO">
                    </div>
                </div>
                <div id="second">
                    <div>
                        <i class="bi bi-calendar3"></i>
                        
                    </div>
                    <div id="date"> <h5>Date of Journey</h5>
                        <p>17Mar,2026<sub>(Today)</sub></p></div>
                    <div><button>Today</button>
                    <button style="color: white;background-color: #F1CECA;">Tomorrow</button></div>
